<section class="p-4 p-md-5 mb-4 rounded-4 bg-dark text-white shadow-sm border border-secondary-subtle">
  <div class="row align-items-center g-4">
    <div class="col-lg-8">
      <p class="text-uppercase text-info small fw-semibold mb-2">Développeur web • univers gaming • créativité</p>
      <h1 class="display-6 fw-bold mb-3">Je construis des expériences web modernes et utiles.</h1>
      <p class="text-light-emphasis mb-4">
        Un portfolio simple, propre et efficace pour présenter mes projets, ma vision et mon style.
      </p>
      <div class="d-flex flex-wrap gap-2">
        <%= link_to "Voir mes projets", projects_path, class: "btn btn-primary px-4" %>
        <%= link_to "Me contacter", contact_path, class: "btn btn-outline-light px-4" %>
      </div>
    </div>
    <div class="col-lg-4 text-lg-end">
      <span class="badge rounded-pill text-bg-info fs-6">Disponible pour de nouveaux projets</span>
    </div>
  </div>
</section>
