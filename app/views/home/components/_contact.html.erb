<div class="contact-grid">
  <!-- Left: Info -->
  <div class="contact-info">
    <h2>Parlons de votre <span class="gradient-text">Projet</span></h2>
    <p>Vous avez une idée ambitieuse ou un besoin technique précis ? Je suis là pour transformer vos concepts en réalité digitale.</p>

    <div class="contact-item">
      <div class="contact-item-icon contact-item-icon--mail">
        <i class="fas fa-envelope"></i>
      </div>
      <div>
        <h4>Email</h4>
        <p>dani.derbala77210@gmail.com</p>
      </div>
    </div>

    <div class="contact-item">
      <div class="contact-item-icon contact-item-icon--discord">
        <i class="fab fa-discord"></i>
      </div>
      <div>
        <h4>Discord</h4>
        <p>da.dan_</p>
      </div>
    </div>
  </div>

  <!-- Right: Form -->
  <div class="glass contact-form-card">
    <form class="form-grid">
      <div class="form-group">
        <label class="form-label">Nom</label>
        <input type="text" class="form-input" placeholder="Votre nom">
      </div>
      <div class="form-group">
        <label class="form-label">Email</label>
        <input type="email" class="form-input" placeholder="votre@email.com">
      </div>
      <div class="form-group form-group--full">
        <label class="form-label">Sujet</label>
        <input type="text" class="form-input" placeholder="Comment puis-je vous aider ?">
      </div>
      <div class="form-group form-group--full">
        <label class="form-label">Message</label>
        <textarea class="form-input" placeholder="Votre message..."></textarea>
      </div>
      <div class="form-group form-group--full">
        <button type="submit" class="btn-glow" style="width: 100%; justify-content: center;">
          Envoyer le message <i class="fas fa-paper-plane"></i>
        </button>
      </div>
    </form>
  </div>
</div>
