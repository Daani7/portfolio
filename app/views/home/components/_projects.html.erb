                  <div style="display:flex; justify-content:space-between;">
                    <span style="color:var(--text-muted);">Méthode Rails :</span>
                    <strong style="color:#fff;">has_delegated_jsonb</strong>
                  </div>
                  <div style="display:flex; justify-content:space-between;">
                    <span style="color:var(--text-muted);">Stockage SQL :</span>
                    <strong class="gradient-text">PostgreSQL JSONB</strong>
                  </div>
                  <div style="display:flex; flex-direction:column; gap:0.4rem; margin-top:0.5rem;">
