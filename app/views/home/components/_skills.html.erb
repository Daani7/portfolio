<div class="section-header" style="text-align: center;">
  <h2>Mon <span class="gradient-text">Stack Technique</span></h2>
  <p style="margin-left: auto; margin-right: auto;">Des outils modernes pour des solutions robustes et évolutives.</p>
</div>

<%
  skill_categories = [
    { title: "Front-end", icon: "fas fa-desktop", variant: "blue",
      skills: ["React", "Next.js", "Tailwind CSS", "TypeScript"] },
    { title: "Back-end", icon: "fas fa-server", variant: "purple",
      skills: ["Ruby on Rails", "Node.js", "PostgreSQL", "Redis"] },
    { title: "Architecture", icon: "fas fa-microchip", variant: "green",
      skills: ["RESTful APIs", "Docker", "CI/CD", "System Design"] }
  ]
%>

<div class="skills-grid">
  <% skill_categories.each do |cat| %>
    <div class="glass skill-card">
      <div class="icon-block icon-block--<%= cat[:variant] %>">
        <i class="<%= cat[:icon] %>"></i>
      </div>
      <h3><%= cat[:title] %></h3>
      <div class="skill-pills">
        <% cat[:skills].each do |skill| %>
          <span class="skill-pill"><%= skill %></span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
