<section class="card border-0 shadow-sm rounded-4">
  <div class="card-body p-4 p-md-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
      <h2 class="h3 fw-bold mb-0">Compétences</h2>
      <span class="text-secondary small">Niveau actuel</span>
    </div>

    <div class="row g-3">
      <% skills.each do |skill| %>
        <div class="col-12 col-md-6 col-xl-4">
          <article class="skill-tile rounded-3 h-100 p-3 border">
            <p class="fw-semibold mb-1"><%= skill[:name] %></p>
            <p class="mb-0 text-primary"><%= skill[:level] %></p>
          </article>
        </div>
      <% end %>
    </div>
  </div>
</section>
