<!DOCTYPE html>
<html lang="fr">
  <head>
    <title>Dani Derbala | Architecte Digital</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Portfolio de Dani Derbala - Architecte d'écosystèmes digitaux. Créateur d'Insight Sphere.">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://kit.fontawesome.com/e674b6cf57.js" crossorigin="anonymous"></script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="bg-ambiance"></div>
    <div class="bg-grid"></div>

    <%= render 'layouts/navbar' %>
    <%= yield %>
    <%= render 'layouts/footer' %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
